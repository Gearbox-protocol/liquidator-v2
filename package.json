{
  "name": "@gearbox-protocol/liquidator-v2",
  "description": "Gearbox liquidation bot",
  "version": "0.0.0-semantic-release",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf build",
    "build": "node esbuild.config.mjs",
    "start": "tsx --env-file .env src/index.ts --config config.yaml | pino-pretty --colorize",
    "prepare": "husky",
    "check": "biome check --write",
    "check:ci": "biome check",
    "typecheck:ci": "tsc --noEmit",
    "test": "vitest",
    "diagnose": "tsx --env-file .env scripts/diagnose.mts"
  },
  "dependencies": {
    "@gearbox-protocol/liquidator-v2-config": "workspace:*",
    "node-pty": "^1.1.0",
    "pino-pretty": "^13.1.3",
    "viem-deal": "^2.0.4"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@biomejs/biome": "^2.4.15",
    "@commander-js/extra-typings": "^14.0.0",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@gearbox-protocol/biome-config": "^1.0.28",
    "@gearbox-protocol/cli-utils": "^6.9.1",
    "@gearbox-protocol/liquidator-contracts": "^v1.36.0-securitize.1",
    "@gearbox-protocol/sdk": "14.8.6",
    "@types/node": "^25.6.2",
    "@vlad-yakovlev/telegram-md": "^2.1.0",
    "abitype": "^1.2.4",
    "axios": "^1.16.0",
    "axios-retry": "^4.5.0",
    "date-fns": "^4.1.0",
    "di-at-home": "^0.0.7",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "nanoid": "^5.1.11",
    "node-pty": "^1.1.0",
    "pino": "^10.3.1",
    "tsx": "4.21.0",
    "typescript": "^6.0.3",
    "viem": "^2.48.11",
    "vitest": "^4.1.5",
    "zod": "^4.4.3"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,mts,mjs,json}": [
      "biome check --no-errors-on-unmatched --write"
    ]
  },
  "packageManager": "pnpm@11.1.1"
}
